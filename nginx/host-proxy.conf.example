# Host nginx (Ubuntu / Plesk / panel) terminating TLS and proxying to the
# Next.js container on 127.0.0.1:3000.
#
# Requirements:
# - Proxy ALL methods (GET, POST, PUT, DELETE, PATCH) — admin CRUD needs PUT/DELETE
# - Canonical host is apex: www → https://tacdent.com (301)
# - Do NOT limit methods with: if ($request_method !~ ^(GET|HEAD|POST)$) { return 405; }

# Redirect www → apex (canonical host)
server {
    listen 80;
    listen [::]:80;
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.tacdent.com;

    # ssl_certificate     /etc/letsencrypt/live/tacdent.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/tacdent.com/privkey.pem;

    return 301 https://tacdent.com$request_uri;
}

server {
    listen 80;
    listen [::]:80;
    server_name tacdent.com;
    return 301 https://tacdent.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name tacdent.com;

    # ssl_certificate     /etc/letsencrypt/live/tacdent.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/tacdent.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
